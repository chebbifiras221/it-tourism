    # Language-specific patterns for greetings
    GREETINGS_EN = {
        "greeting": ["hello", "hi", "hey", "good morning", "good afternoon", "good evening", "greetings"],
        "polite": ["please", "thanks", "thank you", "appreciate", "kindly"],
        "farewell": ["bye", "goodbye", "farewell", "see you", "ciao"]
    }
    
    GREETINGS_IT = {
        "greeting": ["ciao", "salve", "buongiorno", "buonasera", "buonpomeriggio", "ehi"],
        "polite": ["per favore", "grazie", "grazie mille", "prego", "apprezzo"],
        "farewell": ["arrivederci", "addio", "a presto", "ciao ciao"]
    }
    
    # Non-tourism rejection patterns
    REJECTED_TOPICS_EN = ["bitcoin", "programming", "code", "politics", "weather", "sports", 
                         "homework", "health advice", "legal advice", "investment tips"]
    REJECTED_TOPICS_IT = ["bitcoin", "programmazione", "politica", "meteo", "sport", 
                         "compiti", "consiglio medico", "consiglio legale", "consigli su investimenti"]
    
    def __init__(self):
        self.conversation_history = []
        self.context = ConversationContext()
    
    def detect_language(self, text: str) -> Language:
        """
        Detect whether text is in English or Italian
        Returns: Language enum
        """
        import re
        text_lower = text.lower()
        
        # Italian-specific characters - strong indicator
        italian_chars = ["è", "à", "ò", "ù", "ì", "é"]
        if any(char in text_lower for char in italian_chars):
            self.context.language = Language.ITALIAN
            return Language.ITALIAN
        
        # Italian-specific words with word boundaries
        italian_words = ["che", "per", "una", "questo", "quale", "dove", "cosa", 
                        "albergo", "ristorante", "visitare", "tour", "viaggiare",
                        "vorrei", "posso", "ciao", "buongiorno", "buonasera", "grazie",
                        "per favore", "arrivederci", "bellissimo", "meraviglioso", "magnifico",
                        "inizio", "palazzo", "piazza", "cattedrale", "cappella"]
        
        # English-specific words with word boundaries
        english_words = ["the", "and", "is", "are", "this", "that", "have", "been",
                        "hello", "good", "thank", "please", "goodbye", "amazing",
                        "beautiful", "wonderful", "would", "could", "should"]
        
        # Use word boundary matching
        italian_count = sum(1 for word in italian_words if re.search(r'\b' + word + r'\b', text_lower))
        english_count = sum(1 for word in english_words if re.search(r'\b' + word + r'\b', text_lower))
        
        # If Italian words significantly outnumber English, it's Italian
        if italian_count > english_count:
            self.context.language = Language.ITALIAN
            return Language.ITALIAN
        elif italian_count > 0 and english_count == 0:
            # If we found Italian words and no English words, it's Italian
            self.context.language = Language.ITALIAN
            return Language.ITALIAN
        
        self.context.language = Language.ENGLISH
        return Language.ENGLISH
    
    def is_greeting(self, text: str, language: Language) -> bool:
        """Check if message is a greeting - STRICT word boundary matching"""
        import re
        text_lower = text.lower().strip()
        patterns = self.GREETINGS_IT if language == Language.ITALIAN else self.GREETINGS_EN
        
        # Only match greetings at the beginning or as standalone words
        greeting_patterns = patterns.get("greeting", [])
        for greeting in greeting_patterns:
            # Match at start, with word boundaries, or standalone
            if text_lower.startswith(greeting) or re.search(r'\b' + greeting + r'\b', text_lower):
                # If it's a simple greeting without other complex content, it's a greeting
                words = text_lower.split()
                if len(words) <= 3 or any(word == greeting for word in words[:2]):
                    return True
        
        return False
    
    def is_farewell(self, text: str, language: Language) -> bool:
        """Check if message is a farewell - STRICT word boundary matching"""
        import re
        text_lower = text.lower().strip()
        patterns = self.GREETINGS_IT if language == Language.ITALIAN else self.GREETINGS_EN
        
        # Only match farewells at the beginning or as standalone words
        farewell_patterns = patterns.get("farewell", [])
        for farewell in farewell_patterns:
            # Match at start, with word boundaries, or standalone
            if text_lower.startswith(farewell) or re.search(r'\b' + farewell + r'\b', text_lower):
                # If it's a simple farewell without other complex content, it's a farewell
                words = text_lower.split()
                if len(words) <= 3 or any(word == farewell for word in words[:2]):
                    return True
        
        return False
    
    def is_polite(self, text: str, language: Language) -> bool:
        """Check if message contains polite words"""
        text_lower = text.lower()
        patterns = self.GREETINGS_IT if language == Language.ITALIAN else self.GREETINGS_EN
        return any(word in text_lower for word in patterns.get("polite", []))
    
    def is_tourism_related(self, text: str, language: Language) -> bool:
        """Check if message is about tourism/Italy travel - STRICT filtering"""
        text_lower = text.lower()
        
        # Non-tourism topics to reject
        rejected_topics = {
            "technical": ["code", "python", "javascript", "programming", "bug", "error", "function", "program", "debug", "software", "api", "database", "sql", "html", "css"],
            "academic": ["homework", "assignment", "test", "exam", "grade", "study", "essay", "question answer", "math", "biology", "physics", "chemistry", "history date"],
            "personal": ["my life", "my job", "my work", "my love", "my relationship", "my problem", "my health", "my money", "disease", "illness", "sick", "doctor"],
            "politics": ["politics", "election", "vote", "government", "president", "minister", "parliament", "law", "legal", "court", "judge"],
            "sports": ["football", "soccer", "basketball", "tennis", "hockey", "baseball", "game score", "match result", "team", "player"],
            "tech_gadgets": ["laptop", "phone", "iphone", "android", "windows", "mac", "computer", "tablet", "tv", "camera"],
            "news": ["news", "weather", "stock", "market", "bitcoin", "crypto", "company", "business report"],
            "entertainment": ["movie", "film", "series", "show", "episode", "character", "actor", "singer", "music band"],
        }
        
        # Check if text contains rejected topics
        for category, keywords in rejected_topics.items():
            if any(keyword in text_lower for keyword in keywords):
                return False
        
        # Tourism/Italy keywords that MUST be present
        tourism_keywords = [
            # Accommodation
            "hotel", "albergo", "stay", "sleep", "dormir", "lodge", "hostel", "apartment", "room", "camera", "camera",
            # Food/Dining
            "restaurant", "ristorante", "eat", "dining", "dinner", "lunch", "cena", "pranzo", "food", "cibo", "mangiare", "cuisin",
            # Activities
            "visit", "see", "tour", "visit", "explore", "visitare", "esplorare", "attraction", "place", "place to go",
            # Culture
            "museum", "museo", "musei", "art", "arte", "church", "chiesa", "monument", "monumento",
            # Travel/Trip  
            "travel", "trip", "voyage", "journey", "vacation", "holiday", "break", "weekend", "travel", "viaggio", "vacanza",
            # Italy-specific
            "italy", "italia", "italian", "rome", "roma", "venice", "venezia", "florence", "firenze", "milan", "milano", "naples", "napoli",
            # Common request words with Italy context  
            "where", "where to", "best", "recommendations", "suggest", "cosa", "dove", "dove andrare", "migliori",
        ]
        
        # Count how many tourism keywords are present
        tourism_keyword_count = sum(1 for keyword in tourism_keywords if keyword in text_lower)
        
        # Must have at least one tourism keyword
        if tourism_keyword_count > 0:
            return True
        
        # If no tourism keywords found, it's not tourism-related
        return False
    
    def extract_region(self, user_input: str) -> Optional[str]:
        """Extract Italian region/city from user input (supports both languages)"""
        regions = {
            "rome": ["rome", "roma", "lazio", "vatican", "vaticano"],
            "venice": ["venice", "venezia", "veneto", "canal", "canale"],
            "florence": ["florence", "firenze", "tuscany", "toscana", "uffizi"],
            "milan": ["milan", "milano", "lombardy", "lombardia"],
            "naples": ["naples", "napoli", "campania", "pompeii", "pompei"],
        }
        
        input_lower = user_input.lower()
        for region, keywords in regions.items():
            if any(keyword in input_lower for keyword in keywords):
                self.context.last_region = region
                return region
        
        # Return last known region if context available
        if self.context.last_region:
            return self.context.last_region
        
        return None
    
    def extract_intent(self, user_input: str) -> str:
        """Determine what user is looking for (language-agnostic) - more specific matching"""
        input_lower = user_input.lower()
        
        # Specific keywords in order of priority - check specific before general
        specific_intents = {
            "hotel": ["hotel", "accommodation", "stay", "lodging", "sleep", "room", "albergo", "soggiorno", "camera", "dove dormire", "dove alloggiare"],
            "restaurant": ["restaurant", "ristorante", "eat", "ristoranti", "dine", "dining", "food", "dinner", "lunch", "cena", "pranzo", "dove mangiare"],
            "culture": ["museum", "museums", "cultural", "art", "history", "ancient", "monument", "church", "museo", "musei", "arte", "storia", "chiesa"],
            "activity": ["visit", "explore", "tour", "tours", "see", "see the", "what do", "thing to do", "visitare", "esplorare", "attività", "cosa fare"],
        }
        
        # Check for specific keywords first (most exact match)
        for intent, keywords in specific_intents.items():
            for keyword in keywords:
                if keyword in input_lower:
                    self.context.last_intent = intent
                    return intent
        
        # Default to general if no specific intent found
        return "general"
    
    def extract_budget(self, user_input: str) -> str:
        """Extract price preference from user input"""
        input_lower = user_input.lower()
        
        # Check for budget preferences
        luxury_keywords = ["luxury", "5-star", "five star", "expensive", "haute", "best", "finest", "€€€€", "lusso", "stellato"]
        mid_keywords = ["4-star", "four star", "nice", "good", "comfortable", "€€€", "buono", "comodo"]
        budget_keywords = ["budget", "cheap", "affordable", "3-star", "three star", "€€", "economico", "conveniente", "economical"]
        
        if any(keyword in input_lower for keyword in luxury_keywords):
            return "luxury"
        elif any(keyword in input_lower for keyword in budget_keywords):
            return "budget"
        elif any(keyword in input_lower for keyword in mid_keywords):
            return "mid"
        
        return "any"  # No preference specified
    
    def extract_min_rating(self, user_input: str) -> float:
        """Extract minimum rating preference from user input"""
        input_lower = user_input.lower()
        
        # Check for quality preferences
        if any(word in input_lower for word in ["best", "top", "highly rated", "top rated", "migliori", "eccellente"]):
            return 4.6  # Top rated only
        elif any(word in input_lower for word in ["good", "quality", "nice", "buono", "qualità"]):
            return 4.3  # Good quality
        elif any(word in input_lower for word in ["budget", "cheap", "economico"]):
            return 4.0  # Budget but still decent
        
        return 3.0  # Any rating
    
    def get_greeting_response(self, language: Language) -> str:
        """Generate appropriate greeting response"""
        if language == Language.ITALIAN:
            responses = [
                "Ciao! Benvenuto in Italia! 🇮🇹 Sono la tua guida turistica AI. Posso aiutarti a trovare hotel, ristoranti, siti culturali e attività in tutta Italia. Dove pensi di andare?",
                "Buongiorno! Sono felicissimo di aiutarti a pianificare il tuo viaggio italiano. Dammi un città e il tipo di esperienza che cerchi!",
                "Ehi! Ti aiuterò a scoprire il meglio dell'Italia. Che sia Roma, Venezia, Firenze o oltre - dimmi dove e ti darò i migliori consigli! 🏛️"
            ]
        else:
            responses = [
                "Hello! Welcome to Italy! 🇮🇹 I'm your AI tourism guide. I can help you find hotels, restaurants, cultural sites, and activities across Italy. Where are you planning to go?",
                "Hi there! I'm excited to help you plan an amazing Italian vacation. Tell me a city and what kind of experience you're looking for!",
                "Hey! I'll help you discover the best of Italy. Whether it's Rome, Venice, Florence, or beyond - tell me where and I'll give you the best recommendations! 🏛️"
            ]
        
        import random
        return random.choice(responses)
    
    def get_farewell_response(self, language: Language) -> str:
        """Generate appropriate farewell response"""
        if language == Language.ITALIAN:
            responses = [
                "Arrivederci! Divertiti in Italia! 🇮🇹",
                "A presto! Spero di averti aiutato a pianificare un meraviglioso viaggio italiano!",
                "Ciao! Buon viaggio e buon appetito! 🍝"
            ]
        else:
            responses = [
                "Goodbye! Have an amazing time in Italy! 🇮🇹",
                "See you soon! Hope I helped you plan a wonderful Italian adventure!",
                "Bye! Enjoy your trip and buon appetito! 🍝"
            ]
        
        import random
        return random.choice(responses)
    
    def get_rejection_response(self, language: Language) -> str:
        """Generate response for non-tourism questions"""
        if language == Language.ITALIAN:
            return "Mi dispiace, ma posso aiutarti solo con domande sul turismo e i viaggi in Italia. Posso consigliarti hotel, ristoranti, musei, e attività turistiche. Che cosa vorresti visitare?"
        else:
            return "I'm sorry, but I can only help with tourism and travel questions about Italy. I can recommend hotels, restaurants, museums, and tourist activities. What would you like to visit?"
    
    def get_recommendations(self, user_input: str, language: Language) -> Dict:
        """Generate personalized recommendations with smart filtering - STRICT intent matching"""
        region = self.extract_region(user_input)
        intent = self.extract_intent(user_input)
        budget = self.extract_budget(user_input)
        min_rating = self.extract_min_rating(user_input)
        
        # Default to Rome if no region specified
        if not region:
            region = "rome"
        
        region_key = region.split()[0].lower()
        
        recommendations = {
            "region": region,
            "intent": intent,
            "recommendations": [],
            "language": language.value,
            "budget": budget,
            "min_rating": min_rating
        }
        
        def matches_budget(item: Dict) -> bool:
            """Check if item matches budget preference"""
            if budget == "any":
                return True
            
            price = item.get("price", "")
            if budget == "luxury":
                return "€€€€" in price or price == "€€€€"
            elif budget == "mid":
                return "€€€" in price
            elif budget == "budget":
                return "€" in price and "€€€" not in price
            return True
        
        def matches_rating(item: Dict) -> bool:
            """Check if item meets rating preference"""
            rating = item.get("rating", 0)
            return rating >= min_rating
        
        limit = 5  # Return more items
        
        # STRICT intent matching - only return what user asked for
        if intent == "hotel":
            hotels = self.HOTEL_RECOMMENDATIONS.get(region_key, [])
            hotel_count = 0
            for hotel in hotels:
                if hotel_count >= limit:
                    break
                if matches_budget(hotel) and matches_rating(hotel):
                    recommendations["recommendations"].append({
                        "type": "hotel",
                        "icon": "🏨",
                        "name": hotel["name"],
                        "details": f"{hotel['type']} • {hotel['price']} • ⭐{hotel['rating']}",
                        "description": hotel["description"],
                        "link": hotel["link"],
                        "address": hotel.get("address", ""),
                    })
                    hotel_count += 1
        
        elif intent == "restaurant":
            restaurants = self.RESTAURANT_RECOMMENDATIONS.get(region_key, [])
            rest_count = 0
            for restaurant in restaurants:
                if rest_count >= limit:
                    break
                if matches_budget(restaurant) and matches_rating(restaurant):
                    recommendations["recommendations"].append({
                        "type": "restaurant",
                        "icon": "🍝",
                        "name": restaurant["name"],
                        "details": f"{restaurant['cuisine']} • {restaurant['price']} • ⭐{restaurant['rating']}",
                        "description": restaurant['specialty'],
                        "link": restaurant["link"],
                        "address": restaurant.get("address", ""),
                    })
                    rest_count += 1
        
        elif intent == "culture":
            sites = self.CULTURAL_SITES.get(region_key, [])
            site_count = 0
            for site in sites:
                if site_count >= limit:
                    break
                if matches_rating(site):
                    recommendations["recommendations"].append({
                        "type": "culture",
                        "icon": "🏛️",
                        "name": site["name"],
                        "details": f"{site['type']} • ⭐{site['rating']} • {site['ticket_price']}",
                        "description": site["description"],
                        "link": site["link"],
                        "address": site.get("address", ""),
                        "hours": site.get("hours", "TBD")
                    })
                    site_count += 1
        
        elif intent == "activity":
            sites = self.CULTURAL_SITES.get(region_key, [])
            site_count = 0
            for site in sites:
                if site_count >= limit:
                    break
                if matches_rating(site):
                    recommendations["recommendations"].append({
                        "type": "culture",
                        "icon": "🚶",
                        "name": site["name"],
                        "details": f"{site['type']} • ⭐{site['rating']} • {site['ticket_price']}",
                        "description": site["description"],
                        "link": site["link"],
                        "address": site.get("address", ""),
                        "hours": site.get("hours", "TBD")
                    })
                    site_count += 1
        
        else:  # General intent - return mix of all categories
            limit_per_category = 2
            
            # Hotels
            hotels = self.HOTEL_RECOMMENDATIONS.get(region_key, [])
            hotel_count = 0
            for hotel in hotels:
                if hotel_count >= limit_per_category:
                    break
                if matches_budget(hotel) and matches_rating(hotel):
                    recommendations["recommendations"].append({
                        "type": "hotel",
                        "icon": "🏨",
                        "name": hotel["name"],
                        "details": f"{hotel['type']} • {hotel['price']} • ⭐{hotel['rating']}",
                        "description": hotel["description"],
                        "link": hotel["link"],
                        "address": hotel.get("address", ""),
                    })
                    hotel_count += 1
            
            # Restaurants
            restaurants = self.RESTAURANT_RECOMMENDATIONS.get(region_key, [])
            rest_count = 0
            for restaurant in restaurants:
                if rest_count >= limit_per_category:
                    break
                if matches_budget(restaurant) and matches_rating(restaurant):
                    recommendations["recommendations"].append({
                        "type": "restaurant",
                        "icon": "🍝",
                        "name": restaurant["name"],
                        "details": f"{restaurant['cuisine']} • {restaurant['price']} • ⭐{restaurant['rating']}",
                        "description": restaurant['specialty'],
                        "link": restaurant["link"],
                        "address": restaurant.get("address", ""),
                    })
                    rest_count += 1
            
            # Culture
            sites = self.CULTURAL_SITES.get(region_key, [])
            site_count = 0
            for site in sites:
                if site_count >= limit_per_category:
                    break
                if matches_rating(site):
                    recommendations["recommendations"].append({
                        "type": "culture",
                        "icon": "🏛️",
                        "name": site["name"],
                        "details": f"{site['type']} • ⭐{site['rating']} • {site['ticket_price']}",
                        "description": site["description"],
                        "link": site["link"],
                        "address": site.get("address", ""),
                        "hours": site.get("hours", "TBD")
                    })
                    site_count += 1
        
        return recommendations
    
    def generate_response(self, user_input: str, language: Language) -> str:
        """Generate conversational response with smart context awareness"""
        region = self.extract_region(user_input)
        intent = self.extract_intent(user_input)
        budget = self.extract_budget(user_input)
        
        region_name = region.title() if region else ("Italy" if language == Language.ENGLISH else "Italia")
        
        # Build response with budget context
        budget_context = {
            "luxury": (" luxury options", " opzioni di lusso"),
            "mid": (" mid-range options", " opzioni mid-range"),
            "budget": (" affordable options", " opzioni economiche"),
            "any": ("", "")
        }
        
        budget_en, budget_it = budget_context.get(budget, ("", ""))
        
        if language == Language.ITALIAN:
            if intent == "hotel":
                return f"Ti aiuto a trovare l'alloggio perfetto in {region_name}! 🏨 Ecco i migliori hotel{budget_it} con dettagli su prezzi e servizi."
            elif intent == "restaurant":
                return f"Perfetto! Ecco i ristoranti più deliziosi in {region_name}{budget_it}. 🍝 Ho selezionato per te cucina autentica e specialità locali."
            elif intent == "culture":
                return f"Splendido! Ecco le attrazioni culturali imprescindibili in {region_name}. 🏛️ Include musei, monumenti storici e siti UNESCO con orari e tariffe."
            elif intent == "activity":
                return f"Meraviglioso! Ti mostro le migliori cose da fare in {region_name}. 🚶 Esperienze autentiche, tour guidati e attività locali ti aspettano!"
            else:
                return f"Benvenuto a {region_name}! ✨ Ho trovato alcune opzioni interessanti per te. Che cosa ne pensi? Posso approfondire ulteriormente!"
        else:
            if intent == "hotel":
                return f"I'd love to help you find the perfect accommodation in {region_name}! 🏨 Here are the best hotels{budget_en} with pricing and amenity details."
            elif intent == "restaurant":
                return f"Perfect! Here are the most delicious restaurants in {region_name}{budget_en}. 🍝 I've selected authentic cuisine and local specialties just for you."
            elif intent == "culture":
                return f"Wonderful! Here are the must-see cultural attractions in {region_name}. 🏛️ Includes museums, historic monuments, and UNESCO sites with hours and admission fees."
            elif intent == "activity":
                return f"Fantastic! Here's what to do in {region_name}. 🚶 Authentic experiences, guided tours, and local activities are waiting for you!"
            else:
                return f"Welcome to {region_name}! ✨ I found some great options for you. What do you think? I can dive deeper if you'd like!"
    
    def chat(self, user_message: str, language_override: Optional[str] = None) -> Dict:
        """
        Process user message and return recommendations
        
        Args:
            user_message: The user's input text
            language_override: Force language ('en' or 'it'), otherwise auto-detect
        """
        self.context.conversation_turn += 1
        
        # Use provided language or detect from message
        if language_override:
            language = Language.ITALIAN if language_override.lower() == 'it' else Language.ENGLISH
        else:
            language = self.detect_language(user_message)
        
        # Check for special message types
        if self.is_greeting(user_message, language):
            response = self.get_greeting_response(language)
            self.conversation_history.append({
                "user": user_message,
                "assistant": response,
                "timestamp": datetime.utcnow().isoformat(),
                "recommendations": [],
                "type": "greeting"
            })
            return {
                "response": response,
                "recommendations": [],
                "region": None,
                "intent": "greeting",
                "language": language.value,
                "type": "greeting"
            }
        
        if self.is_farewell(user_message, language):
            response = self.get_farewell_response(language)
            self.conversation_history.append({
                "user": user_message,
                "assistant": response,
                "timestamp": datetime.utcnow().isoformat(),
                "recommendations": [],
                "type": "farewell"
            })
            return {
                "response": response,
                "recommendations": [],
                "region": None,
                "intent": "farewell",
                "language": language.value,
                "type": "farewell"
            }
        
        # Check if message is tourism-related
        if not self.is_tourism_related(user_message, language):
            response = self.get_rejection_response(language)
            self.conversation_history.append({
                "user": user_message,
                "assistant": response,
                "timestamp": datetime.utcnow().isoformat(),
                "recommendations": [],
                "type": "rejection"
            })
            return {
                "response": response,
                "recommendations": [],
                "region": None,
                "intent": "rejected",
                "language": language.value,
                "type": "rejection"
            }
        
        # Generate recommendations
        recommendations_data = self.get_recommendations(user_message, language)
        response = self.generate_response(user_message, language)
        
        self.conversation_history.append({
            "user": user_message,
            "assistant": response,
            "timestamp": datetime.utcnow().isoformat(),
            "recommendations": recommendations_data["recommendations"],
            "language": language.value
        })
        
        return {
            "response": response,
            "recommendations": recommendations_data["recommendations"],
            "region": recommendations_data["region"],
            "intent": recommendations_data["intent"],
            "language": language.value,
            "type": "recommendation"
        }


