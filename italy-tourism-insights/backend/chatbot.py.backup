"""
Advanced AI Tourism Chatbot with Multi-Language Support
Handles conversations in English & Italian
Provides intelligent recommendations with real links and explanations
"""
from typing import List, Dict, Optional, Tuple
import re
from datetime import datetime
from enum import Enum


class Language(Enum):
    """Supported languages"""
    ENGLISH = "en"
    ITALIAN = "it"


class ConversationContext:
    """Maintains conversation state for multi-turn conversations"""
    def __init__(self):
        self.language = Language.ENGLISH
        self.last_intent = None
        self.last_region = None
        self.conversation_turn = 0
        self.previous_recommendations = []


